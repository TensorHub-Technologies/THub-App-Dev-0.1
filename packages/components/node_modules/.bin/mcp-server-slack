#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/usr/src/node_modules/.pnpm/@modelcontextprotocol+server-slack@2025.4.25/node_modules/@modelcontextprotocol/server-slack/node_modules:/usr/src/node_modules/.pnpm/@modelcontextprotocol+server-slack@2025.4.25/node_modules:/usr/src/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/usr/src/node_modules/.pnpm/@modelcontextprotocol+server-slack@2025.4.25/node_modules/@modelcontextprotocol/server-slack/node_modules:/usr/src/node_modules/.pnpm/@modelcontextprotocol+server-slack@2025.4.25/node_modules:/usr/src/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@modelcontextprotocol/server-slack/dist/index.js" "$@"
else
  exec node  "$basedir/../@modelcontextprotocol/server-slack/dist/index.js" "$@"
fi
